PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=voicedrop

# Redis
REDIS_URL=redis://localhost:6379

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=voicedrop-audio-bucket

# JWT Secrets
JWT_SECRET=super_secret_jwt_key_replace_me
JWT_REFRESH_SECRET=super_secret_refresh_key_replace_me

# Firebase Admin
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-adminsdk.json
